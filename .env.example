# ========================================
# WIN Marketplace - Variáveis de Ambiente
# ========================================

# ========================================
# 🗄️ BANCO DE DADOS PostgreSQL
# ========================================
POSTGRES_DB=win_marketplace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# ========================================
# 🚀 BACKEND (Spring Boot)
# ========================================
SPRING_PROFILES_ACTIVE=docker
HIBERNATE_DDL_AUTO=update
TZ=America/Sao_Paulo

# ========================================
# 🌐 CORS - Configuração de Origens Permitidas
# ========================================
# Configure os IPs/domínios que podem acessar sua API (separados por vírgula)
# 
# Exemplos:
# - Localhost: http://localhost:3000,http://localhost:5173
# - VPS: http://146.190.136.183,http://146.190.136.183:3000
# - Domínio: https://meusite.com,https://www.meusite.com
# - Múltiplos: http://localhost:3000,http://seu-ip,https://seu-dominio.com
#
# ⚠️ IMPORTANTE: Atualize isso ao fazer deploy na VPS!
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================================
# 📧 EMAIL
# ========================================

# OPÇÃO 1: SendGrid (Recomendado)
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
SENDGRID_API_KEY=
MAIL_FROM=

# OPÇÃO 2: Gmail (Apenas Desenvolvimento)
# Descomente as linhas abaixo e comente a opção 1 para usar o Gmail
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=seu-email@gmail.com
# MAIL_PASSWORD=sua-senha-app-16-caracteres
# MAIL_FROM=seu-email@gmail.com

# ========================================
# 🔧 FERRAMENTAS DE DESENVOLVIMENTO
# ========================================
DEV_TOOLS_ENABLED=true

# ========================================
# 🌐 FRONTEND (React + Vite)
# ========================================
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8080
NODE_ENV=development

# ========================================
# 🥑 ABACATE PAY (Gateway de Pagamento)
# ========================================
# ⚠️ OBRIGATÓRIO para pagamentos PIX funcionarem!
#
# 📋 Como obter suas credenciais:
# 1. Acesse: https://abacatepay.com
# 2. Crie uma conta e faça login
# 3. Vá em Integração > Criar Chave de API
# 4. Copie sua API Key (use chave de DEV MODE para testes)
# 5. Não compartilhe essa chave!
#
# 🔑 API Key - Usado pelo BACKEND para criar cobranças
# Formato: abpk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ABACATEPAY_API_KEY=

# 🔗 URL da API (não precisa alterar)
ABACATEPAY_API_URL=https://api.abacatepay.com

# 🧪 Teste: Use chave de Dev Mode para desenvolvimento
# 🚀 Produção: Use chave de produção apenas em ambiente real