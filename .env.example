# ========================================
# WIN Marketplace - Variáveis de Ambiente
# ========================================

# ========================================
# 🗄️ BANCO DE DADOS PostgreSQL
# ========================================
POSTGRES_DB=win_marketplace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ALTERE_PARA_SENHA_FORTE

# ========================================
# 🚀 BACKEND (Spring Boot)
# ========================================
SPRING_PROFILES_ACTIVE=docker
HIBERNATE_DDL_AUTO=update
TZ=America/Sao_Paulo

# ========================================
# 🌐 CORS - Configuração de Origens Permitidas
# ========================================
# Configure os IPs/domínios que podem acessar sua API (separados por vírgula)
# 
# Exemplos:
# - Localhost: http://localhost:3000,http://localhost:5173
# - VPS: http://146.190.136.183,http://146.190.136.183:3000
# - Domínio: https://meusite.com,https://www.meusite.com
# - Múltiplos: http://localhost:3000,http://seu-ip,https://seu-dominio.com
#
# ⚠️ IMPORTANTE: Atualize isso ao fazer deploy na VPS!
ALLOWED_ORIGINS=https://winmarketplace.com.br,https://www.winmarketplace.com.br,http://winmarketplace.com.br,http://www.winmarketplace.com.br,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ========================================
# 📧 EMAIL
# ========================================

# OPÇÃO 1: SendGrid (Recomendado)
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
SENDGRID_API_KEY=
MAIL_FROM=

# OPÇÃO 2: Gmail (Apenas Desenvolvimento)
# Descomente as linhas abaixo e comente a opção 1 para usar o Gmail
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=seu-email@gmail.com
# MAIL_PASSWORD=sua-senha-app-16-caracteres
# MAIL_FROM=seu-email@gmail.com

# ========================================
# 🔧 FERRAMENTAS DE DESENVOLVIMENTO
# ========================================
DEV_TOOLS_ENABLED=false
API_DOCS_ENABLED=false
JWT_SECRET=ALTERE_PARA_UM_SECRET_COM_64_CARACTERES_OU_MAIS
SECURITY_LOGIN_MAX_ATTEMPTS=5
SECURITY_LOGIN_LOCK_MINUTES=15
SECURITY_LOGIN_USE_REDIS=true
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# ========================================
# 🌐 FRONTEND (React + Vite)
# ========================================
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8080
NODE_ENV=development

# ========================================
# 🚗 UBER DIRECT API - Sistema de Entregas
# ========================================
# Obtenha credenciais em: https://developer.uber.com
# Documentação: https://developer.uber.com/docs/direct
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
UBER_API_BASE_URL=https://sandbox-api.uber.com
UBER_API_ENABLED=false

# 🔐 Webhook Secret (para validação HMAC de webhooks)
# Gerado automaticamente ao configurar webhook no dashboard da Uber
UBER_WEBHOOK_SECRET=

# Google Maps API (para geocoding de endereços)
Maps_API_KEY=

# ========================================
# 💳 PAGAR.ME (STONE) - Gateway de Pagamento PIX
# ========================================
# Dashboard: https://dash.pagar.me/
# Documentação: https://docs.pagar.me/
#
# Ambiente de Teste (Sandbox)
PAGARME_API_KEY=
PAGARME_PUBLIC_KEY=
PAGARME_ENVIRONMENT=test
PAGARME_ENABLED=false

# ========================================
# 🌐 FRONTEND - Configuração da URL da API
# ========================================
# ⚠️ IMPORTANTE: Diferentes entre desenvolvimento e produção
#
# Desenvolvimento Local: http://localhost:8080
# VPS (Docker): http://backend:8080
# VPS (IP externo): http://137.184.87.106:8080
#
VITE_API_BASE_URL=http://localhost:8080