# ========================================
# WIN Marketplace - Variáveis de Ambiente
# ========================================

# ========================================
# 🗄️ BANCO DE DADOS PostgreSQL
# ========================================
POSTGRES_DB=win_marketplace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# ========================================
# 🚀 BACKEND (Spring Boot)
# ========================================
SPRING_PROFILES_ACTIVE=docker
HIBERNATE_DDL_AUTO=update
TZ=America/Sao_Paulo

# ========================================
# 🌐 CORS - Configuração de Origens Permitidas
# ========================================
# Configure os IPs/domínios que podem acessar sua API (separados por vírgula)
# 
# Exemplos:
# - Localhost: http://localhost:3000,http://localhost:5173
# - VPS: http://146.190.136.183,http://146.190.136.183:3000
# - Domínio: https://meusite.com,https://www.meusite.com
# - Múltiplos: http://localhost:3000,http://seu-ip,https://seu-dominio.com
#
# ⚠️ IMPORTANTE: Atualize isso ao fazer deploy na VPS!
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================================
# 📧 EMAIL
# ========================================

# OPÇÃO 1: SendGrid (Recomendado)
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
SENDGRID_API_KEY=
MAIL_FROM=

# OPÇÃO 2: Gmail (Apenas Desenvolvimento)
# Descomente as linhas abaixo e comente a opção 1 para usar o Gmail
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=seu-email@gmail.com
# MAIL_PASSWORD=sua-senha-app-16-caracteres
# MAIL_FROM=seu-email@gmail.com

# ========================================
# 🔧 FERRAMENTAS DE DESENVOLVIMENTO
# ========================================
DEV_TOOLS_ENABLED=true

# ========================================
# 🌐 FRONTEND (React + Vite)
# ========================================
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8080
NODE_ENV=development

# ========================================
# 💳 MERCADO PAGO (Gateway de Pagamento)
# ========================================
# ⚠️ OBRIGATÓRIO para pagamentos PIX e Cartão funcionarem!
#
# 📋 Como obter suas credenciais:
# 1. Acesse: https://www.mercadopago.com.br/developers/panel/app
# 2. Crie uma aplicação ou use uma existente
# 3. Vá em "Credenciais"
# 4. Copie AMBOS os tokens (Access Token E Public Key)
#
# 🔑 Access Token - Usado pelo BACKEND para criar pagamentos
# Formato: APP_USR-XXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX
MERCADOPAGO_ACCESS_TOKEN=

# 🔑 Public Key - Usado pelo FRONTEND (SDK React)
# Formato: APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
VITE_MERCADOPAGO_PUBLIC_KEY=

# 🧪 Teste: Use credenciais de teste para desenvolvimento
# 🚀 Produção: Use credenciais de produção apenas em ambiente real