# ========================================
# WIN Marketplace - .gitignore
# ========================================

# ========================================
# 🔐 SEGURANÇA - NUNCA COMMITAR
# ========================================
# Variáveis de ambiente
.env
.env.local
.env.*.local
.env.production
.env.staging
.env.test
.env.vps*
.env.*.example.local
**/.env.production
**/.env.staging

# Chaves de criptografia e certificados
*.key
*.pem
*.p12
*.pkcs12
*.jks
secrets/
credentials/
.ssh/
.keys/

# Configurações locais/sensíveis
config/application-prod.yml
config/application-local.yml
config/application-*.yml
!config/application.yml
!config/application-dev.yml
backend/src/main/resources/application-prod.yml
backend/src/main/resources/application-local.yml

# ========================================
# 🗄️ BANCO DE DADOS
# ========================================
*.sql.backup
*.dump
*.db
*.sqlite
*.sqlite3
postgres_data/

# ========================================
# ☕ JAVA / SPRING BOOT
# ========================================
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/pom.xml.tag
backend/pom.xml.releaseBackup
backend/pom.xml.versionsBackup
backend/pom.xml.next
backend/release.properties
backend/dependency-reduced-pom.xml
backend/buildNumber.properties
backend/.mvn/timing.properties
backend/!**/src/main/**/target/
backend/!**/src/test/**/target/
backend/*.log
backend/logs/
backend/spring.log
backend/*.class
backend/*.jar
backend/*.war
backend/*.ear
backend/hs_err_pid*

# ========================================
# ⚛️ REACT / NODE.JS
# ========================================
win-frontend/node_modules/
win-frontend/.pnp
win-frontend/.pnp.js
win-frontend/coverage/
win-frontend/build/
win-frontend/dist/
win-frontend/.DS_Store
win-frontend/.env.local
win-frontend/.env.development.local
win-frontend/.env.test.local
win-frontend/.env.production.local
win-frontend/npm-debug.log*
win-frontend/yarn-debug.log*
win-frontend/yarn-error.log*
win-frontend/pnpm-debug.log*
win-frontend/.vite
win-frontend/dist-ssr
win-frontend/*.local

# ========================================
# 🐳 DOCKER
# ========================================
docker-compose.override.yml

# ========================================
# 📤 UPLOADS - Dados do Usuário
# ========================================
uploads/*
!uploads/.gitkeep
temp/
tmp/
*.tmp

# ========================================
# 💻 IDEs
# ========================================
.idea/
*.iml
*.iws
*.ipr
out/
.settings/
.classpath
.project
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
*.swp
*.swo
*~

# ========================================
# 🔧 Arquivos de Teste/Dev Locais
# ========================================
db-check.txt
*-test.html
*-test.js
*-test.json
temp_migrations.sql
*-local.sh
*-local.bat
*-dev.conf
.local/
.test/

# ========================================
# 📊 Logs e Reportes Sensíveis
# ========================================
*.log
logs/
audit.log
access.log
error.log

# ========================================
# 🖥 OS Files
# ========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ========================================
# 📁 Backup e Temp
# ========================================
*.bak
*.backup
*.orig
*.swp
*.tmp
*.temp
.cache/
.metadata
bin/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# ========================================
# 🤖 VS Code Copilot Customizations
# ========================================
# Track local progress (não sincronizar entre devs)
.github/PROGRESS_TRACKING.md
# Mas manter customizações compartilhadas
!.github/copilot-instructions.md
!.github/agents/

# ========================================
# 🖥️ OS
# ========================================
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*~

# ========================================
# 📝 TEMPORÁRIOS
# ========================================
*.log
*.bak
*.swp
*.tmp
temp_*
tmp_*

# ========================================
# 📝 DOCUMENTAÇÃO INTERNA (NÃO PUBLICAR)
# ========================================
_DOCS/
RELATORIO_FINAL.md
scripts/internal/

# ========================================
# ✅ EXCEÇÕES
# ========================================
!.gitkeep
!.env.example
