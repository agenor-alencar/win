# ===========================================
# CONFIGURAÇÕES DE ARMAZENAMENTO DE IMAGENS
# ===========================================

# Tipo de armazenamento: local, s3, digitalocean
STORAGE_TYPE=s3

# ===========================================
# CONFIGURAÇÕES AWS S3 / DigitalOcean Spaces
# ===========================================

# Credenciais AWS (ou DigitalOcean Spaces)
AWS_ACCESS_KEY_ID=sua-access-key-aqui
AWS_SECRET_ACCESS_KEY=sua-secret-key-aqui

# Região (AWS: sa-east-1, us-east-1, etc.)
AWS_REGION=sa-east-1

# Nome do bucket
S3_BUCKET_NAME=win-marketplace-images

# OPCIONAL: Endpoint customizado (para DigitalOcean Spaces ou MinIO)
# DigitalOcean Spaces: https://nyc3.digitaloceanspaces.com
# MinIO: http://localhost:9000
S3_ENDPOINT=

# OPCIONAL: URL pública do CDN (se usar CloudFront ou DigitalOcean CDN)
S3_PUBLIC_URL=

# ===========================================
# CONFIGURAÇÕES DE IMAGENS
# ===========================================

# Tamanho máximo de imagem em MB
IMAGE_MAX_SIZE_MB=10

# Tipos permitidos (separados por vírgula)
IMAGE_ALLOWED_TYPES=jpg,jpeg,png,webp,gif

# Dimensões do thumbnail
IMAGE_THUMBNAIL_WIDTH=300
IMAGE_THUMBNAIL_HEIGHT=300

# Dimensões da versão média
IMAGE_MEDIUM_WIDTH=800
IMAGE_MEDIUM_HEIGHT=800

# ===========================================
# GUIA DE CONFIGURAÇÃO RÁPIDA
# ===========================================

# AWS S3:
# 1. Criar bucket no console AWS: https://console.aws.amazon.com/s3/
# 2. Configurar permissões públicas no bucket
# 3. Criar usuário IAM com permissões S3 (AmazonS3FullAccess)
# 4. Gerar Access Key ID e Secret Access Key
# 5. Preencher as variáveis acima

# DigitalOcean Spaces:
# 1. Criar Space: https://cloud.digitalocean.com/spaces
# 2. Gerar API Key (Spaces access keys)
# 3. Configurar:
#    AWS_ACCESS_KEY_ID=sua-spaces-key
#    AWS_SECRET_ACCESS_KEY=sua-spaces-secret
#    AWS_REGION=nyc3 (ou sua região)
#    S3_BUCKET_NAME=nome-do-seu-space
#    S3_ENDPOINT=https://nyc3.digitaloceanspaces.com

# Google Cloud Storage:
# (Requer implementação adicional do GCS Storage Service)
