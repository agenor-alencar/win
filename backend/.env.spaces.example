# ========================================
# DIGITALOCEAN SPACES - Configuração
# ========================================
# 
# 1. Crie uma conta no DigitalOcean: https://cloud.digitalocean.com/
# 2. Acesse: API -> Spaces Keys -> Generate New Key
# 3. Copie o Access Key e Secret Key
# 4. Crie um Space em: Manage -> Spaces -> Create Space
#
# Copie este arquivo para .env e preencha os valores

# Chaves de acesso do DigitalOcean Spaces
SPACES_ACCESS_KEY=your_spaces_access_key_here
SPACES_SECRET_KEY=your_spaces_secret_key_here

# Nome do bucket (Space) - altere se usar outro nome
SPACES_BUCKET_NAME=win-marketplace-storage

# Endpoint e região (exemplos):
# San Francisco 3: https://sfo3.digitaloceanspaces.com (sfo3)
# New York 3: https://nyc3.digitaloceanspaces.com (nyc3)
# Amsterdam 3: https://ams3.digitaloceanspaces.com (ams3)
# Singapore 1: https://sgp1.digitaloceanspaces.com (sgp1)
SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
SPACES_REGION=sfo3

# ========================================
# CUSTOS ESTIMADOS (Janeiro 2025)
# ========================================
# Armazenamento: $0.02/GB/mês
# Transferência de saída: $0.01/GB (primeiros 1TB grátis)
# Requisições: Grátis
#
# Exemplo: 10GB de imagens + 100GB de tráfego/mês = ~$0.20/mês
